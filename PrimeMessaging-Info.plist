<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>mirowin.PrimeMessaging.notifications.refresh</string>
	</array>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>mirowin.PrimeMessaging.invites</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>primemessaging</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Prime Messaging uses Bluetooth to find nearby devices and exchange nearby messages.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>Prime Messaging uses Bluetooth to find nearby devices and exchange nearby messages.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_prmsgchat._tcp</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>Prime Messaging uses the camera to capture photos and videos for messages.</string>
	<key>NSContactsUsageDescription</key>
	<string>Prime Messaging uses your contacts to show which people you already know are on Prime and to help you invite others. Contact details may be securely processed to match existing users.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Prime Messaging uses Face ID to unlock your protected chats.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Prime Messaging uses the local network to discover nearby devices.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Prime Messaging uses your location to share your current location in chats.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Prime Messaging uses the microphone for audio messages and internet calls.</string>
	<key>NSUserActivityTypes</key>
	<array>
		<string>INSendMessageIntent</string>
	</array>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Prime Messaging saves downloaded photos and videos from chats to your photo library.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Prime Messaging uses your photo library to send photos and choose an avatar.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Prime Messaging uses speech recognition to transcribe voice messages on your device.</string>
	<key>PrimeMessagingServerURL</key>
	<string>$(PRIME_MESSAGING_SERVER_URL)</string>
	<key>PrimeMessagingAppStoreURL</key>
	<string>$(PRIME_MESSAGING_APP_STORE_URL)</string>
	<key>PrimeMessagingHelpCenterURL</key>
	<string>https://primemessaging.site/helpcenter/</string>
	<key>PrimeMessagingInviteURL</key>
	<string>$(PRIME_MESSAGING_INVITE_URL)</string>
	<key>PrimeMessagingPrivacyPolicyURL</key>
	<string>https://primemessaging.site/privacypolicy/</string>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>processing</string>
		<string>fetch</string>
		<string>audio</string>
		<string>voip</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIStatusBarStyle</key>
	<string></string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
